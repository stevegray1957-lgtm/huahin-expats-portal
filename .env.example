# Copy this file to .env and fill in your values
# cp .env.example .env

# Admin panel password (REQUIRED — set this before going live)
ADMIN_PASSWORD=change-me-before-going-live

# Server port (default: 3000)
PORT=3000

# Session secret for admin auth tokens
SESSION_SECRET=replace-with-a-long-random-string

# Site URL (used for canonical tags, sitemaps)
SITE_URL=https://HuaHinExpatsPortal.com
